{
  "name": "evetreemap",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "EVE Online item circulation & consumption visualizer",
  "scripts": {
    "data": "python scripts/build_market_tree.py",
    "killstats": "python scripts/build_kill_stats.py --progress",
    "prices": "python scripts/build_market_prices.py --progress",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
