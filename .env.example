# Copy this file to `.env` (gitignored) and fill in your own contact address.
# The Python data scripts (scripts/build_kill_stats.py, build_market_prices.py)
# read the full ESI User-Agent from ESI_USER_AGENT so it isn't published in the
# repo. ESI etiquette expects a descriptive UA with a way to reach you.
# In CI, set this as a GitHub Actions secret named ESI_USER_AGENT instead.
ESI_USER_AGENT=evetreemap/1.0 (+https://github.com/<you>/evetreemap; <you>@example.com)
